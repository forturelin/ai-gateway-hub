# ============================================================
# AI-Gateway-Hub .gitignore
# ============================================================

# ---- Dependencies ----
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---- Runtime / Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
server.log
server.pid

# ---- Local runtime data (~/.ai-gateway-hub mirrored locally) ----
.ai-gateway-hub/
data/
request-logs/

# ---- Env & secrets ----
.env
.env.*
!.env.example
*.key
*.pem
secrets.json

# ---- Editor / IDE ----
.vscode/
.idea/
.crush
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Build / Cache ----
dist/
build/
.cache/
.tmp/
coverage/
.nyc_output/

# ---- Misc ----
*.bak
*.bak.*
*.tmp
.history/
